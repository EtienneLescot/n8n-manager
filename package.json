{
  "name": "n8n-manager-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Ready-to-run n8n environment manager for humans and AI agents.",
  "type": "module",
  "bin": {
    "n8n-manager": "./packages/cli/dist/index.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/core packages/credentials-manager packages/cli",
    "clean": "rm -rf packages/*/dist packages/*/tsconfig.tsbuildinfo",
    "test": "node --import tsx --test packages/**/*.test.ts",
    "typecheck": "tsc -b packages/core packages/credentials-manager packages/cli --pretty"
  },
  "keywords": [
    "n8n",
    "n8n-as-code",
    "automation",
    "credentials"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3"
  }
}
